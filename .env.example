# Database
POSTGRES_USER=spatialverify
POSTGRES_PASSWORD=spatialverify_dev
POSTGRES_DB=spatialverify
POSTGRES_PORT=5432
DATABASE_URL=postgresql://spatialverify:spatialverify_dev@localhost:5432/spatialverify

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# API
API_PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# JWT
JWT_SECRET=change-me-in-production-use-64-char-secret-key-here-now
JWT_REFRESH_SECRET=change-me-refresh-secret-64-chars-key-here-now
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=spatialverify
S3_REGION=us-east-1
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_FORCE_PATH_STYLE=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Mapbox (mobile app)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# Gemini (optional field assistant only — NOT used for spatial extraction)
GEMINI_API_KEY=
